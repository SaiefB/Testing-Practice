{
  "name": "project-restaurant-page",
  "version": "1.0.0",
  "description": "A responsive restaurant webpage built with HTML, CSS, and JavaScript, showcasing menu items and services. It uses npm for package management and Webpack for asset bundling. This project emphasizes clean, modular code and includes a .gitignore for a professional repository.",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "build": "webpack --config webpack.prod.js",
    "dev": "webpack serve --config webpack.dev.js",
    "deploy": "git subtree push --prefix dist origin gh-pages"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@eslint/css": "^0.7.0",
    "@eslint/js": "^9.25.1",
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.4.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "prettier": "3.5.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.6"
  },
  "jest": {
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    }
  }
}
